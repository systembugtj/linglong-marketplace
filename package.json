{
  "name": "linglong-marketplace",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "turbo run build",
    "validate": "turbo run validate",
    "test": "turbo run test",
    "check": "turbo run check",
    "skills": "pnpm --filter @linglongjs/skill-validator run skills",
    "catalog": "pnpm --filter @linglongjs/marketplace-build run export-catalog",
    "dev": "pnpm --filter @linglongjs/site dev",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "turbo": "^2.5.4"
  }
}
