{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "export-catalog": {
      "dependsOn": ["^build"],
      "outputs": ["../../site/public/catalog.json", "../../site/public/manifest.json"]
    },
    "validate": {
      "dependsOn": ["^build"]
    },
    "test": {},
    "check": {
      "dependsOn": ["validate", "test"]
    }
  }
}
