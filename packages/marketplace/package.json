{
  "name": "@linglongjs/marketplace-build",
  "version": "1.0.0",
  "description": "CLI and APIs to build Claude Code marketplace catalogs (catalog.json, manifest.json)",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "ll-catalog": "./dist/cli/catalog/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "validate": "pnpm --filter @linglongjs/skill-validator run skills",
    "export-catalog": "pnpm run build && node dist/cli/catalog/main.js",
    "test": "vitest run",
    "check": "pnpm run build && pnpm validate && pnpm test"
  },
  "dependencies": {
    "@linglongjs/skill-validator": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^2.1.9"
  },
  "keywords": [
    "claude",
    "claude-code",
    "marketplace",
    "catalog",
    "skills"
  ]
}
